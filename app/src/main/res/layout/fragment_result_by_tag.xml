<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_bottom"
    android:orientation="vertical"
    tools:context=".ui.main.fragment.ResultByTagFragment">

    <!-- ═══════════════════════════════
         HERO HEADER (đồng bộ HomeFragment)
         ═══════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_hero_header"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="52dp"
        android:paddingEnd="20dp"
        android:paddingBottom="22dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/shape_circle_glass"
            android:padding="8dp"
            android:src="@drawable/ic_back"/>

        <!-- Label + Title + Count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrowseBy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.15"
                    android:text="BROWSE BY"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAreaName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="Dessert" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtResultCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_btn_primary"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                tools:text="24 recipes"/>

        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/shape_search_hero"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:alpha="0.6"
                android:src="@drawable/ic_search"/>

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search recipes..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"/>

            <ImageButton
                android:id="@+id/btnClear"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/shape_circle_glass"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ─── FILTER / SORT ROW ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/shape_accent_bar"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ALL RECIPES"
            android:textColor="#2E5E2E"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSort"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Sort"
            android:textAllCaps="false"
            android:textColor="#43A047"
            android:textSize="11sp"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_sort"
            app:iconPadding="4dp"
            app:iconSize="13dp"
            app:iconTint="#43A047"
            app:strokeColor="#A2CB8B"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <!-- ─── LOADING ─── -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="#43A047"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Loading recipes..."
            android:textColor="#4D2E5E2E"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- ─── RECIPE LIST ─── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRecipesByTag"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="16dp"
        android:visibility="visible"/>

    <!-- ─── EMPTY STATE ─── -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/shape_icon_pill_green"
            android:gravity="center">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_reciper"
                android:alpha="0.45"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No recipes found"
            android:textColor="#2E5E2E"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Try a different keyword"
            android:textColor="#80A2CB8B"
            android:textSize="13sp"/>

    </LinearLayout>

</LinearLayout>