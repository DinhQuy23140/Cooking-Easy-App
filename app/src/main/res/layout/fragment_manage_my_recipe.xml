<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_bottom"
    android:orientation="vertical"
    tools:context=".ui.main.fragment.ManageMyRecipeFragment">

    <!-- ═══════════════════════════════
         HERO HEADER (đồng bộ HomeFragment)
         ═══════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_hero_header"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="52dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <!-- Title + New Recipe button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COOKING"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="My Recipes"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddRecipe"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="New Recipe"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="false"
                app:backgroundTint="#43A047"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_add_white"
                app:iconSize="16dp"
                app:iconPadding="4dp"/>

        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/shape_search_hero"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:alpha="0.6"
                android:src="@drawable/ic_search"/>

            <EditText
                android:id="@+id/edtSearchRecipe"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search your recipes..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"/>

            <ImageButton
                android:id="@+id/btnClear"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/shape_circle_glass"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_btn_primary"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/filterDraft"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_circle_glass"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Draft"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/filterPublished"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_circle_glass"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Published"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/filterFavorite"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/shape_circle_glass"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Favorites"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"/>

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- ═══════════════════════════════
         RECIPE LIST
         ═══════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMyRecipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp"
        android:visibility="visible"
        tools:itemCount="4"
        tools:listitem="@layout/item_upload_recipe"/>

    <!-- ═══════════════════════════════
         EMPTY STATE
         ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Icon empty -->
        <LinearLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/shape_icon_pill_green"
            android:gravity="center">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_reciper"
                android:alpha="0.5"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="No recipes yet"
            android:textColor="#2E5E2E"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Start by creating your first recipe"
            android:textColor="#80A2CB8B"
            android:textSize="13sp"
            android:fontFamily="sans-serif"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateFirst"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="22dp"
            android:text="Create Recipe"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="#43A047"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_add_white"
            app:iconSize="16dp"
            app:iconPadding="4dp"/>

    </LinearLayout>

</LinearLayout>