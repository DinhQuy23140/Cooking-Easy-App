<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gradient_bottom"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ─── HEADER ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_result_header"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.15"
                        android:text="COOKING"
                        android:textColor="#6643A047"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="New Recipe"
                        android:textColor="#2E5E2E"
                        android:textSize="22sp"/>

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/shape_circle_glass"
                    android:padding="8dp"
                    android:src="@drawable/ic_delete"/>

            </LinearLayout>

            <!-- ─── MEAL IMAGE ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/shape_section_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_accent_bar"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:text="MEAL IMAGE"
                        android:textColor="#2E5E2E"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Image picker -->
                <FrameLayout
                    android:id="@+id/layoutPickImage"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@drawable/shape_circle_glass">

                    <ImageView
                        android:id="@+id/imgMeal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/layoutImagePlaceholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:alpha="0.4"
                            android:src="@drawable/ic_camera"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Tap to add photo"
                            android:textColor="#4D2E5E2E"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

            <!-- ─── BASIC INFO ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/shape_section_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_accent_bar"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:text="BASIC INFO"
                        android:textColor="#2E5E2E"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Meal name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Meal Name *"
                    android:textColor="#2E5E2E"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/shape_input_field"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/edtMealName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. Spicy Arrabiata Penne"
                        android:inputType="textCapSentences"
                        android:textColor="#2E5E2E"
                        android:textSize="14sp"/>

                </LinearLayout>

                <!-- Category + Area row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Category -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Category"
                            android:textColor="#2E5E2E"
                            android:textSize="12sp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/shape_input_field"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp">

                            <EditText
                                android:id="@+id/edtCategory"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="e.g. Pasta"
                                android:textColor="#2E5E2E"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Area -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Area"
                            android:textColor="#2E5E2E"
                            android:textSize="12sp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/shape_input_field"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp">

                            <EditText
                                android:id="@+id/edtArea"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="e.g. Italian"
                                android:textColor="#2E5E2E"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Tags -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Tags"
                    android:textColor="#2E5E2E"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/shape_input_field"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/edtTags"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. Pasta, Curry"
                        android:textColor="#2E5E2E"
                        android:textSize="13sp"/>

                </LinearLayout>

                <!-- YouTube link -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="YouTube Link"
                    android:textColor="#2E5E2E"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/shape_input_field"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:alpha="0.5"
                        android:src="@drawable/ic_youtobe"/>

                    <EditText
                        android:id="@+id/edtYoutube"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="https://youtube.com/..."
                        android:inputType="textUri"
                        android:textColor="#2E5E2E"
                        android:textSize="13sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── INGREDIENTS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/shape_section_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_accent_bar"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:text="INGREDIENTS"
                        android:textColor="#2E5E2E"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tvIngredientCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_calories_badge"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="10dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="3dp"
                        android:text="0 items"
                        android:textColor="#43A047"
                        android:textSize="11sp"/>

                </LinearLayout>

                <!-- Column header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Ingredient"
                        android:textColor="#4D2E5E2E"
                        android:textSize="11sp"/>

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Measure"
                        android:textColor="#4D2E5E2E"
                        android:textSize="11sp"/>

                    <View
                        android:layout_width="28dp"
                        android:layout_height="1dp"/>

                </LinearLayout>

                <!-- Dynamic ingredient rows -->
                <LinearLayout
                    android:id="@+id/layoutIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- Add ingredient button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddIngredient"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Add Ingredient"
                    android:textAllCaps="false"
                    android:textColor="#43A047"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_add_white"
                    app:iconPadding="4dp"
                    app:iconSize="16dp"
                    app:iconTint="#43A047"
                    app:strokeColor="#A2CB8B"
                    app:strokeWidth="1dp"/>

            </LinearLayout>

            <!-- ─── INSTRUCTIONS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/shape_section_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_accent_bar"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:text="INSTRUCTIONS"
                        android:textColor="#2E5E2E"
                        android:textSize="12sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_input_field"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp">

                    <EditText
                        android:id="@+id/edtInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="top"
                        android:hint="Describe the cooking steps..."
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="5"
                        android:textColor="#2E5E2E"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── VIDEO ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/shape_section_card"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_accent_bar"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:text="COOKING VIDEO"
                        android:textColor="#2E5E2E"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Tab chọn kiểu: Upload hoặc YouTube link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/shape_input_field"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabUploadVideo"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/shape_calories_badge"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="Upload Video"
                        android:textColor="#43A047"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Upload video panel -->
                <LinearLayout
                    android:id="@+id/panelUploadVideo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <!-- Video picker area -->
                    <FrameLayout
                        android:id="@+id/layoutPickVideo"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:background="@drawable/shape_input_field">

                        <!-- Preview thumbnail sau khi chọn -->
                        <ImageView
                            android:id="@+id/imgVideoThumb"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <!-- Play icon overlay -->
                        <ImageView
                            android:id="@+id/icPlayOverlay"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:alpha="0.8"
                            android:src="@drawable/ic_play"
                            android:visibility="gone" />

                        <!-- Placeholder -->
                        <LinearLayout
                            android:id="@+id/layoutVideoPlaceholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:alpha="0.4"
                                android:src="@drawable/ic_video" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Tap to select video"
                                android:textColor="#4D2E5E2E"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="MP4, MOV up to 100MB"
                                android:textColor="#4D2E5E2E"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </FrameLayout>

                    <!-- Video info sau khi chọn -->
                    <LinearLayout
                        android:id="@+id/layoutVideoInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvVideoName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="middle"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:textColor="#2E5E2E"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvVideoSize"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/shape_calories_badge"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="8dp"
                            android:paddingTop="2dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="2dp"
                            android:textColor="#43A047"
                            android:textSize="11sp" />

                        <ImageButton
                            android:id="@+id/btnRemoveVideo"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/shape_input_field"
                            android:padding="6dp"
                            android:src="@drawable/ic_delete" />

                    </LinearLayout>

                </LinearLayout>

                <!-- YouTube link panel -->

            </LinearLayout>

            <!-- ─── ACTION BUTTONS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveDraft"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Save Draft"
                    android:textAllCaps="false"
                    android:textColor="#43A047"
                    android:textSize="13sp"
                    app:cornerRadius="16dp"
                    app:strokeWidth="1dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPublish"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Publish"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    app:backgroundTint="#43A047"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_add_white"
                    app:iconPadding="4dp"
                    app:iconSize="16dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>