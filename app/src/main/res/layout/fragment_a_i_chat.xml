<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_bottom"
    android:orientation="vertical"
    tools:context=".ui.main.fragment.AIChatFragment">

    <!-- ─── HEADER ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_result_header"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="52dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/shape_circle_glass"
                android:padding="8dp"
                android:src="@drawable/ic_back"/>

            <!-- Bot avatar -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_avatar_ring"
                    android:padding="2dp"
                    android:src="@drawable/ic_category"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/shape_online_dot"/>

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Chef AI"
                    android:textColor="#2E5E2E"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Your cooking assistant"
                    android:textColor="#6643A047"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Clear chat -->
            <ImageButton
                android:id="@+id/btnClearChat"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/shape_circle_glass"
                android:padding="8dp"
                android:src="@drawable/ic_delete"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ─── MESSAGES ─── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"/>

    <!-- ─── SUGGESTIONS ─── -->
    <HorizontalScrollView
        android:id="@+id/layoutSuggestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip1"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shape_input_field"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="🍽 Dinner ideas"
                android:textColor="#2E5E2E"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/chip2"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shape_input_field"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="🍗 Cook with chicken"
                android:textColor="#2E5E2E"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/chip3"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shape_input_field"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="🥗 Healthy breakfast"
                android:textColor="#2E5E2E"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/chip4"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/shape_input_field"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="⚡ Quick 15 min meals"
                android:textColor="#2E5E2E"
                android:textSize="12sp"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ─── INPUT BAR ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_result_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/shape_input_field"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <EditText
                android:id="@+id/edtMessage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Ask me anything about food..."
                android:imeOptions="actionSend"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="#2E5E2E"
                android:textSize="13sp"/>

            <ImageButton
                android:id="@+id/btnScan"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/shape_circle_glass"
                android:padding="7dp"
                android:src="@drawable/ic_camera"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="#43A047"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_send_white"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"/>

    </LinearLayout>

</LinearLayout>